font-family = SauceCodePro Nerd Font Mono
font-size = 18
theme = IC Green PPL

# keybindings

# reset default keybindings
keybind=clear

keybind = command+shift+p=toggle_command_palette
keybind = command++=increase_font_size:1
keybind = command+-=decrease_font_size:1

keybind = command+backspace=esc:u
keybind = command+a=select_all
keybind = command+f=start_search
keybind = command+n=new_window
keybind = command+w=close_surface
keybind = alt+arrow_left=esc:b
keybind = alt+arrow_right=esc:f
keybind = unconsumed:escape=end_search

keybind = command+c=copy_to_clipboard:mixed
keybind = copy=copy_to_clipboard:mixed

keybind = command+v=paste_from_clipboard
keybind = paste=paste_from_clipboard
